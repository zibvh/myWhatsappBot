# Copy this file to .env for local development.
# On Render, set these under your service's "Environment" tab instead.

# Command prefix
PREFIX=.

# Your personal WhatsApp number, digits only, with country code, no + or spaces.
# e.g. 15551234567 for a US number. Grants access to owner-only commands.
OWNER_NUMBER=

# The number the BOT ITSELF logs in as (only needed for generate-session.js).
BOT_NUMBER=

# Paste the string that `npm run pair` prints here once you have it.
# Leave empty for local development (you'll get a QR code / pairing code instead).
SESSION_ID=

# "public" = anyone can use the bot. "private" = only OWNER_NUMBER can.
MODE=public

# How many .warn's before a group member is auto-kicked.
MAX_WARNINGS=3

# Health-check server port. Render sets this automatically — you usually
# don't need to set it yourself.
PORT=3000

BOT_NAME=MyBot
